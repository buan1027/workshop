APP_ADDR=:3000
DATABASE_URL=postgres://gebrauchtwagen:gebrauchtwagen@localhost:5432/gebrauchtwagen?sslmode=disable
RESET_DATABASE_ON_START=true

# Optional auth modes: admin-token or keycloak.
AUTH_MODE=admin-token

# Optional: when set, write operations require Authorization: Bearer <token>.
ADMIN_TOKEN=

# Optional Keycloak/OIDC settings. Used only when AUTH_MODE=keycloak.
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/gebrauchtwagen
KEYCLOAK_CLIENT_ID=workshop-server
